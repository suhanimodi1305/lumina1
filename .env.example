# ─────────────────────────────────────────────────────────────────────────────
# Lumina — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django core ───────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE-ME-generate-a-real-secret-key

# Set to False in production — True only for local development
DEBUG=True

# Comma-separated list of allowed hostnames (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# Trusted origins for CSRF (include your production domain)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── External API Keys ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
HF_API_KEY=your-huggingface-key-here
GROQ_API_KEY=your-groq-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GROK_API_KEY=your-xai-grok-api-key-here

# ── Email (SMTP via Gmail) ────────────────────────────────────────────────────
# Use a Gmail App Password (not your main password). Enable 2FA → App Passwords.
EMAIL_HOST_USER=suhanimodi7090@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
DEFAULT_FROM_EMAIL=Lumina <suhanimodi7090@gmail.com>

# ── Security notes ────────────────────────────────────────────────────────────
# Production checklist:
#   1. SECRET_KEY must be unique and never shared
#   2. DEBUG=False in production
#   3. ALLOWED_HOSTS must list only your real domain(s)
#   4. CSRF_TRUSTED_ORIGINS must include your https:// domain
#   5. Run:  python manage.py check --deploy
