APP_NAME="Lumina Beauty Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kolkata

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lumina_beauty
DB_USERNAME=root
DB_PASSWORD=

# ── Cache / Queue / Session ────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ───────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@lumina.beauty"
MAIL_FROM_NAME="${APP_NAME}"

# ── Python AI Service ─────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TOKEN=
AI_SERVICE_TIMEOUT=30
AI_SERVICE_RETRY=1

# ── External AI APIs (used by Python service) ─────────
GROQ_API_KEY=
GEMINI_API_KEY=
HF_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=

# ── Makeup API (optional sync) ────────────────────────
MAKEUP_API_URL=https://makeup-api.herokuapp.com/api/v1/products.json
MAKEUP_API_ENABLED=true

# ── Filament Admin ────────────────────────────────────
FILAMENT_FILESYSTEM_DISK=public

# ── AWS (optional — for S3 media storage) ────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Vite ──────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
